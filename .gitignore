# === Docker Volumes / Local Data ===
mysql_data/
chroma_data/

# === Backend (Spring Boot) ===
Backend/target/
Backend/.mvn/wrapper/maven-wrapper.jar
Backend/uploads/
application.properties
!**/src/main/**/target/
!**/src/test/**/target/

# === Frontend (React / Vite) ===
Frontend/node_modules/
Frontend/dist/
Frontend/dist-ssr/
Frontend/.tanstack/
Frontend/*.local
Frontend/.env*
!Frontend/.env.example

# === IDEs and Editors ===
.idea/
*.iws
*.iml
*.ipr
.vscode/
*.code-workspace

### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

### NetBeans ###
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

